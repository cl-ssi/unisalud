{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "actived/microsoft-teams-notifier": "^1.3",
        "awcodes/filament-gravatar": "^2.0",
        "barryvdh/laravel-dompdf": "^3.0",
        "blade-ui-kit/blade-icons": "^1.8",
        "calebporzio/sushi": "^2.4",
        "cheesegrits/filament-google-maps": "^3.0",
        "filament/filament": "^3.3.34",
        "hasnayeen/themes": "^3.0",
        "laravel/framework": "^11.45",
        "laravel/sanctum": "^4.0",
        "league/flysystem": "^3.30.0",
        "league/commonmark": "^2.8.2",
        "phpseclib/phpseclib": "^3.0.52",
        "symfony/http-foundation": "^7.3.7",
        "symfony/process": "^7.3.11",
        "owen-it/laravel-auditing": "^14",
        "spatie/laravel-permission": "^6.21",
        "spatie/laravel-google-cloud-storage": "^2.3",
        "stackkit/laravel-google-cloud-tasks-queue": "^5.0",
        "google/protobuf": "^4.33.6",
        "psr/simple-cache": "^3.0",
        "pxlrbt/filament-environment-indicator": "^2.2",
        "pxlrbt/filament-excel": "^2.4",
        "yemenopensource/filament-excel": "^0.1.0",
        "maatwebsite/excel": "^3.1.69",
        "phpoffice/phpspreadsheet": "^1.30.4",
        "ryangjchandler/blade-capture-directive": "1.0 as 0.3",
        "socialiteproviders/claveunica": "^4.2",
        "stechstudio/filament-impersonate": "^3.16",
        "vancuren/php-turf": "^1.0.4"
    },
    "require-dev": {
        "fakerphp/faker": "^1.24",
        "laravel/pint": "^1.24",
        "laravel/sail": "^1.44",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.8",
        "phpunit/phpunit": "^11.5.50",
        "laravel/tinker": "^2.10",
        "psy/psysh": "^0.12.19"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}